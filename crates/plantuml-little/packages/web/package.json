{
  "name": "@actrium/plantuml-little-web",
  "version": "1.2026.2-3",
  "description": "wasm-bindgen wrapper for plantuml-little — run PlantUML → SVG in the browser",
  "type": "module",
  "license": "GPL-3.0-or-later OR LGPL-3.0-or-later OR Apache-2.0 OR EPL-2.0 OR MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kookyleo/plantuml-little.git",
    "directory": "packages/web"
  },
  "homepage": "https://github.com/kookyleo/plantuml-little",
  "bugs": {
    "url": "https://github.com/kookyleo/plantuml-little/issues"
  },
  "author": "kookyleo <kookyleo@gmail.com>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wasm": {
      "types": "./dist/wasm/plantuml_little_web.d.ts",
      "import": "./dist/wasm/plantuml_little_web.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:wasm": "bun ../../../../scripts/wasm-pack.ts build --target bundler --no-pack --out-dir dist/wasm --out-name plantuml_little_web && rm -f dist/wasm/.gitignore",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:wasm && npm run build:ts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@actrium/graphviz-anywhere-web": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@actrium/graphviz-anywhere-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "keywords": [
    "plantuml",
    "puml",
    "svg",
    "wasm",
    "diagram",
    "uml",
    "graphviz"
  ]
}
