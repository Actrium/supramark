{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs/api",
  "exclude": ["**/__tests__/**", "**/*.test.ts", "**/node_modules/**", "**/features.*.ts"],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "includeVersion": true,
  "readme": "README.md",
  "plugin": [],
  "name": "@supramark/core API Documentation",
  "navigationLinks": {
    "GitHub": "https://github.com/Actrium/supramark"
  },
  "categorizeByGroup": true,
  "categoryOrder": ["Core", "AST", "Parser", "Plugin", "Feature Interface", "Cache", "*"],
  "sort": ["source-order"],
  "gitRevision": "main",
  "lightHighlightTheme": "light-plus",
  "darkHighlightTheme": "dark-plus",
  "includeHierarchySummary": true,
  "searchInComments": true,
  "searchInDocuments": true
}
