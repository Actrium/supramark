{
  "name": "@supramark/core",
  "version": "0.1.0",
  "description": "supramark 核心：AST 类型定义、Markdown 解析与插件系统。",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.rn.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.rn.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "dependencies": {
    "katex": "^0.16.9",
    "markdown-it": "^14.0.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-texmath": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-emoji": "^2.0.4",
    "jest-environment-jsdom": "^30.2.0",
    "typedoc": "^0.28.15",
    "typescript": "^5.5.0"
  }
}
